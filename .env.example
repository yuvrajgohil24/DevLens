# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql://devlens:devlens@localhost:5432/devlens

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Backend ───────────────────────────────────────────────
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ── GitHub (Phase 2 — for real deploy triggers) ───────────
GITHUB_TOKEN=ghp_your_personal_access_token
GITHUB_OWNER=your-github-username
GITHUB_REPO=your-repo-name

# ── Frontend ──────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=http://localhost:4000

# ── Auth (Phase 3 — Clerk) ────────────────────────────────
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# ── Slack Alerts  ─────────────────────────────────────
SLACK_WEBHOOK_URL=your-slack-webhook-url

# ── Local Development ─────────────────────────────────────
# Path where all your local git repositories are stored
LOCAL_WORKSPACE_DIR=C:\projects

# Optional: Path to specific scanner binaries if not in system PATH
TRIVY_BIN=
SNYK_TOKEN=your_snyk_api_token_here
